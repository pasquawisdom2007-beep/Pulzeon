# ─────────────────────────────────────────────────────────────
# Pulzeon — Environment Variables
# Copy this file to `.env` (local) and set the same values in
# Vercel / Render dashboards for production.
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (free tier works fine)
# Get it from: MongoDB Atlas > Cluster > Connect > Drivers
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pulzeon?retryWrites=true&w=majority"

# NextAuth — REQUIRED
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Public URL of the deployed app (no trailing slash).
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary — used for payment-proof + product file/image uploads (free tier)
# Get these from: Cloudinary Dashboard > Product Environment Credentials
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Seed admin account (used by `npm run seed`)
ADMIN_NAME="Pulzeon Admin"
ADMIN_EMAIL="admin@pulzeon.com"
ADMIN_PASSWORD="PulzeonAdmin123!"
